---
import Layout from '../components/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton';
---

<Layout 
  title="Servicios Médicos"
  description="Servicios médicos integrales: Guardia 24hs, Ginecología, Neonatología, Diagnóstico por Imágenes, Internación y más en Instituto Médico del Sur, Trelew."
>

  <!-- ══ PAGE HERO ══ -->
  <section class="sv-hero">
    <div class="sv-hero-bg"></div>
    <div class="sv-hero-overlay"></div>
    <!-- floating blobs -->
    <div class="sv-blob sv-blob-1"></div>
    <div class="sv-blob sv-blob-2"></div>

    <div class="sv-hero-inner">
      <span class="sv-hero-badge">
        <span class="sv-hero-badge-dot"></span>
        Instituto Médico del Sur
      </span>
      <h1 class="sv-hero-title">Nuestros <em>Servicios</em></h1>
      <p class="sv-hero-sub">Atención médica integral con tecnología de vanguardia y profesionales comprometidos con tu bienestar.</p>
      <div class="sv-hero-pills">
        <span class="sv-pill">Guardia 24 hs</span>
        <span class="sv-pill">Diagnóstico por imágenes</span>
        <span class="sv-pill">Especialidades</span>
        <span class="sv-pill">Internación</span>
      </div>
    </div>

    <!-- scroll indicator -->
    <div class="sv-scroll-hint">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- ══ MAIN CONTENT ══ -->
  <main class="sv-page">

    <!-- ── GUARDIA Y EMERGENCIAS ── -->
    <section class="sv-section">
      <div class="sv-section-header">
        <div class="sv-badge"><span class="sv-badge-dot"></span>Urgencias</div>
        <h2 class="sv-title">Guardia y <span class="sv-gradient">Emergencias</span></h2>
        <div class="sv-divider"></div>
      </div>

      <div class="sv-guardia-wrap">
        <div class="sv-guardia-card">
          <div class="sv-guardia-left">
            <div class="sv-guardia-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div>
              <div class="sv-guardia-active">
                <span class="sv-pulse"></span>
                Guardia Activa
              </div>
              <h3 class="sv-guardia-title">Guardia Médica 24 Horas</h3>
              <p class="sv-guardia-desc">Atención de urgencias y emergencias médicas las 24 horas del día, los 365 días del año. Equipo médico permanente, equipamiento de última generación y ambulancia para traslados.</p>
              <div class="sv-guardia-features">
                <span class="sv-feature-chip">
                  <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  Equipo permanente
                </span>
                <span class="sv-feature-chip">
                  <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  Ambulancia disponible
                </span>
                <span class="sv-feature-chip">
                  <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                  365 días al año
                </span>
              </div>
              <a href="/horarios" class="sv-btn-primary">
                Ver horarios
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          <div class="sv-guardia-stat-col">
            <div class="sv-stat">
              <span class="sv-stat-num">24</span>
              <span class="sv-stat-label">horas / día</span>
            </div>
            <div class="sv-stat-divider"></div>
            <div class="sv-stat">
              <span class="sv-stat-num">365</span>
              <span class="sv-stat-label">días al año</span>
            </div>
            <div class="sv-stat-divider"></div>
            <div class="sv-stat">
              <span class="sv-stat-num">30+</span>
              <span class="sv-stat-label">años de servicio</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── ESPECIALIDADES ── -->
    <section class="sv-section sv-section--alt">
      <div class="sv-section-header">
        <div class="sv-badge"><span class="sv-badge-dot"></span>Médicos</div>
        <h2 class="sv-title">Especialidades <span class="sv-gradient">Médicas</span></h2>
        <div class="sv-divider"></div>
      </div>

      <div class="sv-cards-3">
        <!-- Ginecología -->
        <div class="sv-card">
          <div class="sv-card-icon sv-card-icon--pink">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="5"/><path d="M12 13v8M9 18h6"/></svg>
          </div>
          <h3 class="sv-card-title">Ginecología y Obstetricia</h3>
          <p class="sv-card-desc">Atención integral de la salud de la mujer: controles ginecológicos, control prenatal, ecografías obstétricas, parto y puerperio.</p>
          <div class="sv-card-footer">
            <a href="https://wa.me/5492804666745" target="_blank" rel="noopener" class="sv-btn-wa">
              <svg width="13" height="13" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Turno por WhatsApp
            </a>
          </div>
        </div>

        <!-- Neonatología -->
        <div class="sv-card">
          <div class="sv-card-icon sv-card-icon--blue">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12H15M12 9v6"/><rect x="3" y="3" width="18" height="18" rx="4"/></svg>
          </div>
          <h3 class="sv-card-title">Neonatología</h3>
          <p class="sv-card-desc">Cuidado especializado de recién nacidos sanos y prematuros. Sala equipada con incubadoras, monitores y tecnología de punta.</p>
          <div class="sv-card-footer">
            <span class="sv-card-tag">Especialidad disponible</span>
          </div>
        </div>

        <!-- Consultorio Externo -->
        <div class="sv-card">
          <div class="sv-card-icon sv-card-icon--teal">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="sv-card-title">Consultorio Externo</h3>
          <p class="sv-card-desc">Consultas ambulatorias con profesionales en diversas especialidades. Atención personalizada y seguimiento continuo de pacientes.</p>
          <div class="sv-card-footer">
            <a href="/profesionales" class="sv-btn-outline">
              Ver profesionales
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── DIAGNÓSTICO POR IMÁGENES ── -->
    <section class="sv-section">
      <div class="sv-section-header">
        <div class="sv-badge"><span class="sv-badge-dot"></span>Tecnología</div>
        <h2 class="sv-title">Diagnóstico por <span class="sv-gradient">Imágenes</span></h2>
        <p class="sv-section-desc">Equipamiento de última generación para estudios de diagnóstico con informes elaborados por especialistas.</p>
        <div class="sv-divider"></div>
      </div>

      <div class="sv-cards-4">
        <div class="sv-card sv-card--compact">
          <div class="sv-card-icon sv-card-icon--indigo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3 class="sv-card-title">Radiología Digital</h3>
          <p class="sv-card-desc">Estudios digitales con menor radiación y mayor precisión. Resultados en el día.</p>
        </div>

        <div class="sv-card sv-card--compact">
          <div class="sv-card-icon sv-card-icon--cyan">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h3 class="sv-card-title">Ecografía</h3>
          <p class="sv-card-desc">Ecografías generales, obstétricas, ginecológicas y de partes blandas. Coordinación por WhatsApp.</p>
          <a href="https://wa.me/5492804692909" target="_blank" rel="noopener" class="sv-btn-wa sv-btn-wa--sm">
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>

        <div class="sv-card sv-card--compact">
          <div class="sv-card-icon sv-card-icon--violet">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
          </div>
          <h3 class="sv-card-title">Resonador Abierto</h3>
          <p class="sv-card-desc">Resonancia magnética abierta, ideal para pacientes claustrofóbicos. Mayor comodidad y precisión diagnóstica.</p>
        </div>

        <div class="sv-card sv-card--compact">
          <div class="sv-card-icon sv-card-icon--orange">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="sv-card-title">Densitometría Ósea</h3>
          <p class="sv-card-desc">Mide la densidad mineral ósea para diagnosticar osteoporosis y evaluar riesgo de fracturas.</p>
        </div>
      </div>
    </section>

    <!-- ── INTERNACIÓN ── -->
    <section class="sv-section sv-section--alt">
      <div class="sv-section-header">
        <div class="sv-badge"><span class="sv-badge-dot"></span>Internación</div>
        <h2 class="sv-title">Internación y <span class="sv-gradient">Cirugía</span></h2>
        <div class="sv-divider"></div>
      </div>

      <div class="sv-cards-2">
        <div class="sv-card sv-card--featured">
          <div class="sv-card-icon sv-card-icon--blue">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>
          </div>
          <h3 class="sv-card-title">Internación Clínica</h3>
          <p class="sv-card-desc">Salas de internación equipadas con monitoreo continuo, enfermería especializada las 24 horas y comodidades para el paciente y acompañante.</p>
          <ul class="sv-feature-list">
            <li>Monitoreo continuo</li>
            <li>Enfermería 24 hs</li>
            <li>Habitaciones confortables</li>
          </ul>
        </div>

        <div class="sv-card sv-card--featured">
          <div class="sv-card-icon sv-card-icon--teal">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="sv-card-title">Internación Quirúrgica</h3>
          <p class="sv-card-desc">Quirófanos modernos con tecnología de vanguardia para cirugías de mediana y alta complejidad. Equipo quirúrgico altamente capacitado.</p>
          <ul class="sv-feature-list">
            <li>Quirófanos de última generación</li>
            <li>Cirugías de alta complejidad</li>
            <li>Equipo especializado</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ── CTA ── -->
    <section class="sv-cta">
      <div class="sv-cta-blob sv-cta-blob-1"></div>
      <div class="sv-cta-blob sv-cta-blob-2"></div>
      <div class="sv-cta-inner">
        <span class="sv-cta-badge">Estamos para ayudarte</span>
        <h2 class="sv-cta-title">¿Necesitás más información?</h2>
        <p class="sv-cta-desc">Contactanos para consultar disponibilidad, solicitar turnos o resolver tus dudas. Atendemos con calidez y compromiso.</p>
        <div class="sv-cta-actions">
          <a href="/turnos" class="sv-cta-btn sv-cta-btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Solicitar turno
          </a>
          <a href="tel:2804421121" class="sv-cta-btn sv-cta-btn--ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8 19.79 19.79 0 01.02 3.12 2 2 0 012 .93h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            280 4421121
          </a>
        </div>
        <div class="sv-cta-trust">
          <span>Guardia 24 hs</span>
          <span class="sv-trust-sep">·</span>
          <span>10+ profesionales</span>
          <span class="sv-trust-sep">·</span>
          <span>30+ años de experiencia</span>
        </div>
      </div>
    </section>

  </main>

  <WhatsAppButton 
    client:load
    phone="2804421121"
    message="Hola, quisiera consultar sobre los servicios médicos disponibles."
  />
</Layout>

<style>
  /* ──────────────────────────────────────
     GLOBAL TOKENS
  ────────────────────────────────────── */
  :root {
    --sv-primary:   #0074B7;
    --sv-secondary: #00A8E1;
    --sv-accent:    #005A8C;
    --sv-dark:      #003554;
    --sv-bg:        #f7f9fc;
    --sv-border:    rgba(0,116,183,0.10);
  }

  /* ──────────────────────────────────────
     HERO
  ────────────────────────────────────── */
  .sv-hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--sv-dark);
  }
  .sv-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #001e36 0%, #003554 40%, #005A8C 100%);
  }
  .sv-hero-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .sv-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    pointer-events: none;
  }
  .sv-blob-1 {
    width: 480px; height: 480px;
    background: rgba(0,116,183,0.18);
    top: -120px; right: -80px;
  }
  .sv-blob-2 {
    width: 300px; height: 300px;
    background: rgba(0,168,225,0.12);
    bottom: -80px; left: 10%;
  }
  .sv-hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 80px 24px 100px;
    max-width: 740px;
    margin: 0 auto;
  }
  .sv-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,116,183,0.20);
    border: 1px solid rgba(0,168,225,0.35);
    color: #00A8E1;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 7px 18px;
    border-radius: 100px;
    margin-bottom: 24px;
  }
  .sv-hero-badge-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #00A8E1;
    box-shadow: 0 0 8px rgba(0,168,225,0.8);
  }
  .sv-hero-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: #fff;
    margin: 0 0 18px;
  }
  .sv-hero-title em {
    font-style: normal;
    background: linear-gradient(135deg, #00A8E1, #60c2f5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .sv-hero-sub {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: rgba(255,255,255,0.68);
    line-height: 1.7;
    margin: 0 auto 32px;
    max-width: 520px;
  }
  .sv-hero-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }
  .sv-pill {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255,255,255,0.75);
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.14);
    padding: 6px 16px;
    border-radius: 100px;
  }
  .sv-scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.3);
    animation: sv-bounce 2s ease-in-out infinite;
    z-index: 2;
  }
  @keyframes sv-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* ──────────────────────────────────────
     PAGE WRAPPER
  ────────────────────────────────────── */
  .sv-page {
    background: var(--sv-bg);
