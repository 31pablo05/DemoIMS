---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import DoctorCard from '../components/DoctorCard.astro';
import WhatsAppButton from '../components/WhatsAppButton';
---

<Layout 
  title="Profesionales"
  description="Equipo médico altamente capacitado en Ginecología, Obstetricia y Neonatología. Profesionales con matrícula provincial en Instituto Médico del Sur, Trelew."
>
  <Hero 
    title="Nuestros Profesionales"
    subtitle="Médicos especializados comprometidos con tu salud y bienestar"
    variant="secondary"
  />

  <section class="py-16">
    <div class="container mx-auto px-4">
      <!-- Ginecología y Obstetricia -->
      <div class="mb-16">
        <div class="text-center mb-12">
          <h2 class="section-title">Ginecología y Obstetricia</h2>
          <p class="section-subtitle max-w-3xl mx-auto">
            Equipo de profesionales especializados en salud de la mujer, control prenatal, partos y cirugías ginecológicas. Atención personalizada con calidez humana.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <DoctorCard 
            name="Dr. Leandro González"
            specialty="Ginecología y Obstetricia"
          />
          <DoctorCard 
            name="Dr. Esteban Greczylo"
            specialty="Ginecología y Obstetricia"
          />
          <DoctorCard 
            name="Dr. Federico Marz"
            specialty="Ginecología y Obstetricia"
          />
          <DoctorCard 
            name="Dra. Aylen Saldivia"
            specialty="Ginecología y Obstetricia"
          />
          <DoctorCard 
            name="Dr. Juan Carlos Salvatierra"
            specialty="Ginecología y Obstetricia"
          />
          <DoctorCard 
            name="Dr. Rodolfo Tommasino"
            specialty="Ginecología y Obstetricia"
          />
        </div>

        <div class="text-center mt-8">
          <a 
            href="https://wa.me/5492804666745?text=Hola,%20quisiera%20solicitar%20un%20turno%20con%20Ginecolog%C3%ADa"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center space-x-2 bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-8 rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span>Solicitar Turno Ginecología</span>
          </a>
        </div>
      </div>

      <!-- Neonatología -->
      <div class="mb-16">
        <div class="text-center mb-12">
          <h2 class="section-title">Neonatología</h2>
          <p class="section-subtitle max-w-3xl mx-auto">
            Médicos especializados en el cuidado del recién nacido. Atención en sala de neonatología y seguimiento ambulatorio con matrículas provinciales activas.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          <DoctorCard 
            name="Dr. Martín Pérez"
            specialty="Neonatología"
            mp="MP 3670"
          />
          <DoctorCard 
            name="Dr. Matías Mendelevich"
            specialty="Neonatología"
            mp="MP 3772"
          />
          <DoctorCard 
            name="Dr. Gustavo Kraguic"
            specialty="Neonatología"
            mp="MP 3561"
          />
          <DoctorCard 
            name="Dr. Fabricio Contreras"
            specialty="Neonatología"
            mp="MP 2375"
          />
        </div>
      </div>

      <!-- Información adicional -->
      <div class="bg-gradient-to-r from-primary to-secondary rounded-2xl p-12 text-center text-white">
        <h2 class="text-3xl font-bold mb-4">¿Querés solicitar un turno?</h2>
        <p class="text-xl mb-8 max-w-2xl mx-auto">
          Contactanos por WhatsApp o por teléfono y coordinamos tu consulta con el profesional que necesites
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="/turnos" class="bg-white text-primary hover:bg-gray-100 font-bold py-4 px-8 rounded-lg transition-all duration-300 shadow-xl hover:shadow-2xl inline-flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Formulario de Turnos
          </a>
          <a href="/servicios" class="border-2 border-white text-white hover:bg-white hover:text-primary font-bold py-4 px-8 rounded-lg transition-all duration-300">
            Ver Servicios
          </a>
        </div>
      </div>
    </div>
  </section>

  <WhatsAppButton 
    client:load
    phone="2804421121"
    message="Hola, quisiera consultar por un turno médico."
  />
</Layout>
