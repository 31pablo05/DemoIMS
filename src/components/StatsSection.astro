---
const stats = [
  {
    numero: '30+',
    texto: 'Años de Experiencia',
    descripcion: 'Liderando la medicina regional',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="8" y="14" width="32" height="28" rx="3" stroke="currentColor" stroke-width="2"/>
      <path d="M16 14V10a8 8 0 0116 0v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <path d="M24 24v8M20 28h8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
    </svg>`
  },
  {
    numero: '10+',
    texto: 'Profesionales',
    descripcion: 'Especialistas de alto nivel',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="18" cy="16" r="7" stroke="currentColor" stroke-width="2"/>
      <circle cx="34" cy="19" r="5" stroke="currentColor" stroke-width="2"/>
      <path d="M4 38c0-7.18 6.268-13 14-13s14 5.82 14 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <path d="M34 32c3.866 0 7 2.686 7 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>`
  },
  {
    numero: '24/7',
    texto: 'Guardia Médica',
    descripcion: 'Atención sin interrupciones',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="24" cy="24" r="17" stroke="currentColor" stroke-width="2"/>
      <path d="M24 12v13l7 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="24" cy="24" r="2" fill="currentColor"/>
    </svg>`
  },
  {
    numero: '15k+',
    texto: 'Pacientes Atendidos',
    descripcion: 'Vidas transformadas con cuidado',
    icon: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M24 38s-16-9.5-16-21a10 10 0 0120 0 10 10 0 0120 0c0 11.5-24 21-24 21z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`
  }
];
---

<section class="stats-section" aria-labelledby="stats-heading">
  <div class="stats-inner">

    <!-- Header -->
    <header class="stats-header" data-animate>
      <p class="stats-eyebrow">Instituto Médico del Sur</p>
      <h2 id="stats-heading" class="stats-title">
        Más de tres décadas de confianza<br/>en la salud de la comunidad
      </h2>
    </header>

    <!-- Stats row -->
    <div class="stats-grid">
      {stats.map((stat, i) => (
        <div
          class="stat-item"
          data-animate
          style={`--delay: ${i * 100}ms`}
        >
          <div class="stat-icon" set:html={stat.icon} />
          <div class="stat-number" data-target={stat.numero}>
            <span class="number-value">{stat.numero}</span>
          </div>
          <div class="stat-label">{stat.texto}</div>
          <div class="stat-desc">{stat.descripcion}</div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .stats-section {
    background: linear-gradient(160deg, #f0f7ff 0%, #e8f4fb 50%, #eef5fb 100%);
    border-top: 3px solid #00CCE8;
    padding: 88px 5% 96px;
    font-family: 'Inter', system-ui, sans-serif;
  }

  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── HEADER ── */
  .stats-header {
    text-align: center;
    margin-bottom: 64px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .stats-header.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stats-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #00CCE8;
    margin-bottom: 14px;
  }

  .stats-title {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #010e23;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* ── GRID ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid #e5eaf2;
    border-radius: 8px;
    overflow: hidden;
  }

  /* ── STAT ITEM ── */
  .stat-item {
    padding: 48px 32px 44px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border-right: 1px solid #e5eaf2;
    background: #ffffff;
    box-shadow: 0 1px 3px rgba(0,100,160,0.06);
    transition: background 0.25s ease;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s ease var(--delay, 0ms),
      transform 0.6s ease var(--delay, 0ms),
      background 0.25s ease;
  }
  .stat-item:last-child {
    border-right: none;
  }
  .stat-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .stat-item:hover {
    background: #f4fbff;
  }

  /* icon */
  .stat-icon {
    width: 36px;
    height: 36px;
    color: #00CCE8;
    margin-bottom: 20px;
    opacity: 0.9;
  }
  .stat-icon svg {
    width: 100%;
    height: 100%;
  }

  /* number */
  .stat-number {
    font-size: clamp(2.6rem, 4vw, 3.6rem);
    font-weight: 800;
    color: #010e23;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 12px;
  }

  /* label */
  .stat-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: #1a2e45;
    margin-bottom: 6px;
  }

  /* desc */
  .stat-desc {
    font-size: 0.76rem;
    font-weight: 400;
    color: #8a9bb0;
    line-height: 1.5;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat-item:nth-child(2) { border-right: none; }
    .stat-item:nth-child(1),
    .stat-item:nth-child(2) {
      border-bottom: 1px solid #e5eaf2;
    }
  }
  @media (max-width: 480px) {
    .stats-section { padding: 64px 5% 72px; }
    .stats-header { margin-bottom: 40px; }
    .stat-item { padding: 36px 20px; }
    .stat-number { font-size: 2.4rem; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

  const parseNum = (str: string) => parseFloat(str.replace(/[^0-9.]/g, ''));
  const formatNum = (n: number, original: string) => {
    const hasK = original.includes('k');
    const hasPlus = original.includes('+');
    if (original.includes('/')) return original;
    let out = hasK ? `${Math.round(n / 1000)}k` : `${Math.round(n)}`;
    if (hasPlus) out += '+';
    return out;
  };

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const original = el.dataset.target || '';
      const target = parseNum(original);
      if (isNaN(target) || original.includes('/')) return;
      const span = el.querySelector('.number-value') as HTMLElement;
      if (!span) return;
      const duration = 1400;
      const start = performance.now();
      const ease = (t: number) => 1 - Math.pow(1 - t, 3);
      const tick = (now: number) => {
        const t = Math.min((now - start) / duration, 1);
        span.textContent = formatNum(target * ease(t), original);
        if (t < 1) requestAnimationFrame(tick);
        else span.textContent = original;
      };
      requestAnimationFrame(tick);
      counterObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  document.querySelectorAll('.stat-number').forEach(el => counterObserver.observe(el));
</script>