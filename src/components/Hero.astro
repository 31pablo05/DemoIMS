---
interface Props {
  title: string;
  subtitle?: string;
  cta?: {
    text: string;
    href: string;
  };
  secondary?: {
    text: string;
    href: string;
  };
  image?: string;
  variant?: 'primary' | 'secondary';
}

const { title, subtitle, cta, secondary, image, variant = 'primary' } = Astro.props;
---

<section
  class:list={[
    'relative overflow-hidden py-16 md:py-24',
    variant === 'primary'
      ? 'bg-gradient-to-br from-[#003554] via-[#0074B7] to-[#00A8E1]'
      : 'bg-gradient-to-br from-[#001525] via-[#002d4a] to-[#004070]'
  ]}
>
  <!-- Subtle grid pattern -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.045]"
    style="background-image: linear-gradient(to right, rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(to bottom, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 80px 80px;"
  ></div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class:list={['max-w-3xl', image ? 'md:max-w-xl' : '']}>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4 tracking-tight">
        {title}
      </h1>
      {subtitle && (
        <p class="text-lg md:text-xl text-white/70 mb-8 leading-relaxed max-w-xl">
          {subtitle}
        </p>
      )}
      {(cta || secondary) && (
        <div class="flex flex-col sm:flex-row gap-3">
          {cta && (
            <a
              href={cta.href}
              class="inline-flex items-center justify-center gap-2 bg-white text-[#003554] hover:bg-blue-50 font-bold py-3.5 px-7 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
            >
              {cta.text}
            </a>
          )}
          {secondary && (
            <a
              href={secondary.href}
              class="inline-flex items-center justify-center gap-2 border-2 border-white/35 text-white hover:bg-white/10 hover:border-white/55 font-semibold py-3.5 px-7 rounded-xl transition-all duration-300"
            >
              {secondary.text}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
